# Cloudflare local dev secrets
# Copy this file to .dev.vars (git-ignored) and fill in real values.
# These are used by `npm run cf:preview` (wrangler dev) only.
# For production, set secrets in the Cloudflare dashboard:
#   Workers & Pages > hephaestus > Settings > Variables and Secrets

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_APP_URL=http://localhost:8788

CLICKSEND_USERNAME=your_clicksend_email_here
CLICKSEND_API_KEY=your_clicksend_api_key_here
CLICKSEND_FROM_NUMBER=+1XXXXXXXXXX
CLICKSEND_WEBHOOK_SECRET=a_random_secret_string

CRON_SECRET=a_long_random_secret_for_cron_endpoints
